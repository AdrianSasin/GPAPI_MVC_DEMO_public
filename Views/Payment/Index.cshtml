@model GPAPI_MVC_DEMO.Models.PaymentRequestModel
@{
    decimal amount = 21.37m;
}

<style>
    .layout-wrapper {
        display: flex;
        flex-direction: row;
        gap: 30px;
        max-width: 1000px;
        margin: 0 auto;
        font-family: inherit;
        color: #333;
    }

    .main-form {
        background-color: #f8fafc;
        padding: 40px 30px 30px 30px;
        border: 1px solid #e5e7eb; 
        border-radius: 12px;       
        flex: 1 1 50%;
        min-width: 300px;
    }

    .product-summary {
        background-color: #f8fafc;
        padding: 30px;
        border: 1px solid #e5e7eb; 
        border-radius: 12px;       
        flex: 0 1 350px;
        height: fit-content;
        position: sticky;
        top: 20px;
    }

    @@media (max-width: 768px) {
        .layout-wrapper {
            flex-direction: column-reverse;
            gap: 20px;
        }
        
        .product-summary {
            flex: 1 1 auto;
            max-width: 100%;
            position: static;
        }
    }

    #AppContainer[data-lang="EN"] .lang-pl { display: none !important; }
    #AppContainer[data-lang="PL"] .lang-en { display: none !important; }

    .form-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 25px;
    }

    .lang-switcher {
        display: flex;
        gap: 5px;
    }

    .lang-btn {
        background-color: #f3f4f6;
        border: 1px solid #e5e7eb; 
        border-radius: 6px;        
        padding: 5px 10px;
        cursor: pointer;
        font-weight: bold;
        color: #374151;
        transition: background-color 0.2s;
    }

    .lang-btn:hover {
        background-color: #e5e7eb;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-group label {
        display: block;
        margin-bottom: 5px;
        font-weight: 500;
        color: #555;
        font-size: 14px;
    }

    .form-group input:not([type="hidden"]) {
        width: 100%;
        padding: 10px;
        border: 1px solid #e5e7eb; 
        border-radius: 6px;
        font-size: 14px;
        box-sizing: border-box;
        outline: none;
        transition: border-color 0.2s;
        background-color: #fafafa;
    }

    .form-group input:focus {
        border-color: #9ca3af;
        background-color: #ffffff;
    }

    .btn-minimal {
        background-color: #475569;
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 12px 24px;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        transition: background-color 0.2s ease-in-out;
        width: 100%;    
        text-align: center;
    }

    .btn-minimal:hover {
        background-color: #334155;
    }

    .btn-blik {
        background-color: #9f1239;
    }

    .btn-blik:hover {
        background-color: #881337;
    }

    .payment-box {
        border: 1px solid #e5e7eb;
        padding: 24px;
        margin-top: 25px;
        background-color: #f8fafc;
        border-radius: 8px;
        box-shadow: 
            4px 4px 8px rgba(0, 0, 0, 0.08),
            -4px -4px 8px rgba(255, 255, 255, 1);
    }

    .payment-note {
        padding-left: 80px; 
        font-size: 13px; 
        color: #6b7280; 
        line-height: 1.4;
        margin-top: 5px;
    }

    .payment-note a {
        color: #2563eb;
        text-decoration: none;
    }

    .payment-note a:hover {
        text-decoration: underline;
    }

    .product-image-placeholder {
        width: 100%;
        height: 200px;
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;        
        margin-bottom: 20px;
        overflow: hidden;
        border-top-left-radius: 8px;
        border-top-right-radius: 8px;
    }

    .product-image-placeholder img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .product-details {
        border-top: 1px solid #e5e7eb;
        border-bottom: 1px solid #e5e7eb;
        padding: 15px 0;
        margin-bottom: 15px;
    }

    .product-total {
        display: flex;
        justify-content: space-between;
        font-size: 18px;
        font-weight: 600;
    }

    .form-card {
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 
            2px 2px 4px rgba(0, 0, 0, 0.1),
            -2px -2px 4px rgba(255, 255, 255, 1);
    }

    h2 {
        font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; 
        font-size: 19px;
        font-weight: 700;
        margin: 0 0 20px 0; 
        color: #1e293b;
        position: relative;
        display: flex;
        align-items: center;
        gap: 12px;
        letter-spacing: -0.02em;
    }

    h2:after {
        content: "";
        position: absolute;
        width: 100%;
        height: 2px;
        bottom: -8px; 
        left: 0;
        background: linear-gradient(to right, #cbd5e1, transparent); 
    }

    .step-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border: 2px solid #cbd5e1;
        border-radius: 50%;
        font-size: 15px;
        font-weight: 700;
        color: #475569;
        background-color: #f8fafc;
        flex-shrink: 0;
    }

    .left-column {
        flex: 1 1 50%;
        min-width: 300px;
        display: flex;
        flex-direction: column;
    }
</style>

<div class="layout-wrapper" id="AppContainer" data-lang="PL">

    <div class="left-column">
        
        <div class="form-header">
            <h1 style="font-size: 24px; font-weight: 600; margin: 0;">
                <span class="lang-pl">Demo eService GPAPI .NET SDK</span>
                <span class="lang-en">eService GPAPI .NET SDK Demo</span>
            </h1>
            
            <div class="lang-switcher">
                <button type="button" class="lang-btn" onclick="setLanguage('PL')">PL</button>
                <button type="button" class="lang-btn" onclick="setLanguage('EN')">EN</button>
            </div>
        </div>

        @if (ViewBag.Error != null)
        {
            <div style="background-color: #fef2f2; border-left: 4px solid #ef4444; color: #991b1b; padding: 12px; margin-bottom: 25px; font-size: 14px; border-radius: 6px;">
                <strong>
                    <span class="lang-pl">Błąd:</span>
                    <span class="lang-en">Error:</span>
                </strong> @ViewBag.Error
            </div>
        }

        <form asp-action="Index" method="post" style="display: flex; flex-direction: column; height: 100%;">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Language" id="LanguageInput" value="PL" />
            <input type="hidden" asp-for="Amount" value="@amount" id="AmountInput" />

            <h2>
                <span class="step-badge">1</span>
                <span class="lang-pl">Dane kontaktowe</span>
                <span class="lang-en">Contact Details</span>
            </h2>
            
            <div class="form-card">
                <div class="form-group">
                    <label>
                        <span class="lang-pl">Imię</span>
                        <span class="lang-en">First Name</span>
                    </label>
                    <input asp-for="FirstName" />
                </div>

                <div class="form-group">
                    <label>
                        <span class="lang-pl">Nazwisko</span>
                        <span class="lang-en">Last Name</span>
                    </label>
                    <input asp-for="LastName" />
                </div>

                <div class="form-group">
                    <label>
                        <span class="lang-pl">Email</span>
                        <span class="lang-en">Email</span>
                    </label>
                    <input asp-for="Email" />
                </div>

                <div class="form-group">
                    <label>
                        <span class="lang-pl">Adres</span>
                        <span class="lang-en">Address</span>
                    </label>
                    <input asp-for="Address" />
                </div>

                <div class="form-group">
                    <label>
                        <span class="lang-pl">Miasto</span>
                        <span class="lang-en">City</span>
                    </label>
                    <input asp-for="City" />
                </div>

                <div class="form-group">
                    <label>
                        <span class="lang-pl">Kod pocztowy</span>
                        <span class="lang-en">Postal Code</span>
                    </label>
                    <input asp-for="PostalCode" />
                </div>
            </div>

            <h2>
                <span class="step-badge">2</span>
                <span class="lang-pl">Wybierz metodę płatności</span>
                <span class="lang-en">Select payment method</span>
            </h2>
            
            <div class="payment-box">
                <div style="margin-bottom: 25px;">
                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <div style="width: 60px; flex-shrink: 0; text-align: center; margin-right: 20px;">
                            <img src="~/images/payments/cards.png" alt="Karta płatnicza" style="width: 100%; max-width: 50px; opacity: 0.9;" />
                        </div>
                        <button type="submit" class="btn-minimal" formaction="/Payment/Index">
                            <span class="lang-pl">Zapłać kartą przez HPP</span>
                            <span class="lang-en">Pay by card via HPP</span>
                        </button>
                    </div>
                    <div class="payment-note">
                        <span class="lang-pl">Demonstracja Hosted Payment Page:</span>
                        <span class="lang-en">Hosted Payment Page Demonstration:</span> <br />
                        <a href="https://developer.eservicegateway.com/docs/payments/online/hosted-payment-page-overview" target="_blank">
                            <span class="lang-pl">Zobacz dokumentację eService &rarr;</span>
                            <span class="lang-en">View eService documentation &rarr;</span>
                        </a>
                    </div>
                </div>

                <div>
                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <div style="width: 60px; flex-shrink: 0; text-align: center; margin-right: 20px;">
                            <img src="~/images/payments/blik.png" alt="BLIK" style="width: 100%; max-width: 50px; opacity: 0.9;" />
                        </div>
                        <button type="submit" class="btn-minimal btn-blik" formaction="/Payment/Blik">
                            <span class="lang-pl">Zapłać BLIK</span>
                            <span class="lang-en">Pay with BLIK</span>
                        </button>
                    </div>
                    <div class="payment-note">
                        <span class="lang-pl">Demonstracja APM BLIK:</span>
                        <span class="lang-en">APM BLIK Demonstration:</span> <br />
                        <a href="https://developer.eservicegateway.com/docs/payments/payment-methods/blik-overview" target="_blank">
                            <span class="lang-pl">Zobacz dokumentację eService &rarr;</span>
                            <span class="lang-en">View eService documentation &rarr;</span>
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <div class="product-summary">
        <h2 style="font-size: 18px; font-weight: 600; margin-top: 0; margin-bottom: 20px;">
            <span class="lang-pl">Podsumowanie zamówienia</span>
            <span class="lang-en">Order Summary</span>
        </h2>

        <div class="product-image-placeholder">
            <img src="~/images/payments/terminal.jpg" alt="Terminal płatniczy od eService" />
        </div>

        <div class="product-details">
            <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                <span>
                    <span class="lang-pl">Niezawodny terminal</span>
                    <span class="lang-en">Reliable POS</span>
                </span>
                <span>1 x</span>
            </div>
            <div style="color: #6b7280; font-size: 13px;">
                <span class="lang-pl">od najlepszej firmy :)</span>
                <span class="lang-en">from the best company :)</span>
            </div>
        </div>

        <div class="product-total">
            <span>
                <span class="lang-pl">Do zapłaty:</span>
                <span class="lang-en">Total:</span>
            </span>
            <span>@amount.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) PLN</span>
        </div>
    </div>

</div>

<script>
    function setLanguage(lang) {
        document.getElementById('LanguageInput').value = lang;
        document.getElementById('AppContainer').setAttribute('data-lang', lang);
    }
</script>