@model GPAPI_MVC_DEMO.Models.PaymentRequestModel

@{
    decimal amount = 2137m;
}

<style>
    :root {
        --primary: #0474C4;
        --primary-dark: #06457F;
        --secondary: #5379AE;
        --background: #A8C4EC;
        --dark-teal: #2C444C;
        --dark-navy: #262B40;

        --surface: #f7faff;
        --white: #ffffff;
        --border: #9bb7dc;
        --text: #262B40;
        --muted: #5d6578;
        --radius: 10px;
    }

    .required {
        color: #dc2626;
        margin-left: 3px;
        font-weight: 700;
    }

    * {
        box-sizing: border-box;
    }

    body {
        background:
            linear-gradient(
                135deg,
                #A8C4EC 0%,
                #dce9f9 50%,
                #A8C4EC 100%
            );
        color: var(--text);
    }

    .layout-wrapper {
        display: flex;
        align-items: stretch; /* było flex-start */
        gap: 36px;
        max-width: 1050px;
        margin: 40px auto;
        padding: 32px;
        background: var(--white);
        border: 2px solid var(--secondary);
        border-radius: 20px;
        box-shadow: 0 20px 45px rgba(6, 69, 127, 0.18);
    }

    .left-column {
        display: flex;
        flex: 1 1 620px;
        flex-direction: column;
        min-width: 0;
        max-width: 620px;
    }

    .right-column {
        flex: 0 0 350px;
        width: 350px;
        min-width: 300px;
        /* Kolumna ma wysokość lewej części strony */
        align-self: stretch;
    }

    .form-card {
        margin-bottom: 20px;
        padding: 24px;
        background: #f7faff;
        border: 1px solid rgba(83, 121, 174, 0.35);
        border-radius: 16px;
        box-shadow: 0 10px 24px rgba(6, 69, 127, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }

    .payment-box {
        margin-top: 20px;
        padding: 24px;
        background: #f7faff;
        border: 1px solid rgba(83,121,174,.35);
        border-radius: 16px;
        box-shadow: 0 10px 24px rgba(6,69,127,.08), inset 0 1px 0 rgba(255,255,255,.8);
    }

    .product-summary {
        position: sticky;
        top: 20px;
        width: 100%;
        height: fit-content;
        padding: 24px;
        background: #f7faff;
        border: 1px solid rgba(83, 121, 174, 0.35);
        border-radius: 16px;
        box-shadow: 0 10px 24px rgba(6, 69, 127, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }

    .checkout-form {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .form-header,
    .payment-method-row,
    .product-row,
    .product-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .form-header {
        align-items: flex-start;
        margin-bottom: 25px;
    }

    .page-title {
        margin: 0;
        color: var(--dark-navy);
        font-size: 24px;
        font-weight: 600;
    }

    .lang-switcher {
        display: flex;
        gap: 5px;
    }

    .lang-btn,
    .btn-minimal {
        border: 0;
        border-radius: 7px;
        cursor: pointer;
        font-weight: 500;
        transition:
            background-color 0.2s,
            border-color 0.2s,
            color 0.2s,
            transform 0.2s,
            box-shadow 0.2s;
    }

    .lang-btn {
        padding: 6px 11px;
        border: 2px solid var(--secondary);
        background: var(--white);
        color: var(--dark-navy);
        font-weight: 700;
    }

    .lang-btn:hover {
        border-color: var(--primary);
        background: var(--background);
        color: var(--primary-dark);
    }

    #AppContainer[data-lang="EN"] .lang-pl,
    #AppContainer[data-lang="PL"] .lang-en {
        display: none !important;
    }

    .error-box {
        margin-bottom: 25px;
        padding: 12px;
        border: 1px solid #ef9a9a;
        border-left: 4px solid #c62828;
        border-radius: 6px;
        background: #fff5f5;
        color: #8e1b1b;
        font-size: 14px;
    }

    h2 {
        margin: 0 0 20px;
        color: var(--dark-navy);
        font-size: 20px;
        font-weight: 600;
    }

    .summary-title {
        color: var(--dark-navy);
        font-size: 18px;
        font-weight: 600;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-group:last-child {
        margin-bottom: 0;
    }

    .form-group label {
        display: block;
        margin-bottom: 5px;
        color: var(--dark-navy);
        font-size: 14px;
        font-weight: 500;
    }

    .form-group input:not([type="hidden"]) {
        width: 100%;
        padding: 11px 12px;
        border: 2px solid var(--border);
        border-radius: 8px;
        outline: none;
        background: var(--white);
        color: var(--text);
        font-size: 14px;
        transition:
            border-color 0.2s,
            box-shadow 0.2s,
            background-color 0.2s;
    }

    .form-group input:not([type="hidden"]):hover {
        border-color: var(--secondary);
    }

    .form-group input:not([type="hidden"]):focus {
        border-color: var(--primary);
        background: var(--white);
        box-shadow: 0 0 0 4px rgba(4, 116, 196, 0.16);
    }

    .payment-method {
        margin-bottom: 25px;
        padding-bottom: 5px;
        border-bottom: 1px solid rgba(83, 121, 174, 0.25);
    }

    .payment-method:last-child {
        margin-bottom: 0;
        border-bottom: 0;
    }

    .payment-method-row {
        justify-content: flex-start;
        align-items: center;
        margin-bottom: 10px;
    }

    .payment-logo {
        display: flex;
        flex: 0 0 70px;
        align-items: center;
        justify-content: center;
        min-height: 54px;
        margin-right: 20px;
    }

    .payment-logo img {
        width: 100%;
        max-width: 50px;
        max-height: 70px;
        object-fit: contain;
        opacity: 0.95;
    }

    .btn-minimal {
        position: relative;
        width: 100%;
        min-height: 54px;
        padding: 14px 24px;
        border: 2px solid var(--primary-dark);
        border-bottom-width: 5px;
        border-radius: 12px;
        background: var(--primary);
        color: var(--white);
        font-size: 16px;
        font-weight: 700;
        letter-spacing: 0.2px;
        text-align: center;
        cursor: pointer;
        box-shadow: 0 6px 12px rgba(6, 69, 127, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.22);
        transition: transform 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
    }

        .btn-minimal::after {
            content: "›";
            position: absolute;
            top: 50%;
            right: 18px;
            transform: translateY(-53%);
            font-size: 26px;
            font-weight: 700;
            line-height: 1;
            opacity: 0.9;
            transition: transform 0.15s ease;
        }

        .btn-minimal:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 10px 18px rgba(6, 69, 127, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.2);
        }

            .btn-minimal:hover::after {
                transform: translate(4px, -53%);
            }

        .btn-minimal:active {
            transform: translateY(2px);
            border-bottom-width: 2px;
            box-shadow: 0 3px 6px rgba(6, 69, 127, 0.22), inset 0 2px 4px rgba(0, 0, 0, 0.12);
        }

        .btn-minimal:focus-visible {
            outline: 4px solid rgba(4, 116, 196, 0.25);
            outline-offset: 3px;
        }

    .btn-blik {
        border-color: #171c30;
        background: var(--dark-navy);
        box-shadow: 0 6px 12px rgba(38, 43, 64, 0.24), inset 0 1px 0 rgba(255, 255, 255, 0.18);
    }

        .btn-blik:hover {
            border-color: #101422;
            background: #171c30;
            box-shadow: 0 10px 18px rgba(38, 43, 64, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.18);
        }

    .btn-bank-payment {
        border-color: #3c5f8c;
        background: var(--secondary);
        box-shadow: 0 6px 12px rgba(83, 121, 174, 0.26), inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }

        .btn-bank-payment:hover {
            border-color: #304f78;
            background: #406796;
            box-shadow: 0 10px 18px rgba(83, 121, 174, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.2);
        }

    .btn-eraty {
        border-color: #1d3036;
        background: var(--dark-teal);
        box-shadow: 0 6px 12px rgba(44, 68, 76, 0.26), inset 0 1px 0 rgba(255, 255, 255, 0.18);
    }

        .btn-eraty:hover {
            border-color: #17282d;
            background: #1e343b;
            box-shadow: 0 10px 18px rgba(44, 68, 76, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.18);
        }

    .payment-note {
        min-height: 58px;
        margin-top: 5px;
        padding-left: 90px;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.4;
    }

    .payment-note a {
        color: var(--primary);
        font-weight: 500;
        text-decoration: none;
    }

    .payment-note a:hover {
        color: var(--primary-dark);
        text-decoration: underline;
    }

    .product-image-placeholder {
        height: 200px;
        margin-bottom: 20px;
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--surface);
    }

    .product-image-placeholder img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .product-details {
        margin-bottom: 15px;
        padding: 15px 0;
        border-block: 1px solid var(--border);
    }

    .product-row {
        margin-bottom: 8px;
        color: var(--dark-navy);
    }

    .product-description {
        color: var(--muted);
        font-size: 13px;
    }

    .product-total {
        color: var(--dark-navy);
        font-size: 18px;
        font-weight: 600;
    }

    .validation-summary {
        margin-bottom: 20px;
        padding: 12px 16px;
        border: 1px solid #ef9a9a;
        border-left: 4px solid #c62828;
        border-radius: 8px;
        background: #fff5f5;
        color: #8e1b1b;
        font-size: 14px;
    }

    .validation-summary:empty,
    .validation-summary.validation-summary-valid {
        display: none;
    }

    .validation-summary ul {
        margin: 0;
        padding-left: 20px;
    }

    .field-validation-error {
        display: block;
        margin-top: 6px;
        color: #c62828;
        font-size: 13px;
        line-height: 1.35;
    }

    .field-validation-valid {
        display: none;
    }

    .form-group input.input-validation-error:not([type="hidden"]) {
        border-color: #c62828;
        background: #fffafa;
        box-shadow: 0 0 0 3px rgba(198, 40, 40, 0.12);
    }

    .form-group input.input-validation-error:not([type="hidden"]):focus {
        border-color: #c62828;
        box-shadow: 0 0 0 3px rgba(198, 40, 40, 0.16);
    }

    @@media (max-width: 768px) {
        body {
            background: var(--background);
        }

        .layout-wrapper {
            flex-direction: column;
            gap: 20px;
            margin: 15px;
            padding: 20px;
        }

        .left-column,
        .right-column {
            width: 100%;
            min-width: 0;
            max-width: none;
        }

        .right-column {
            flex: 1 1 auto;
        }

        .product-summary {
            position: static;
            width: 100%;
            max-width: 100%;
        }

        .form-header {
            gap: 15px;
        }

        .page-title {
            font-size: 21px;
        }

        .payment-logo {
            flex-basis: 55px;
            margin-right: 12px;
        }

        .payment-note {
            padding-left: 67px;
        }
    }

    @@media (max-width: 480px) {
        .layout-wrapper {
            margin: 8px;
            padding: 15px;
            border-radius: 14px;
        }

        .form-header {
            flex-direction: column;
        }

        .payment-box,
        .form-card,
        .product-summary {
            padding: 16px;
        }

        .payment-method-row {
            align-items: stretch;
        }

        .payment-logo {
            flex-basis: 45px;
            margin-right: 10px;
        }

        .payment-logo img {
            max-width: 42px;
        }

        .payment-note {
            min-height: 0;
            padding-left: 55px;
        }

        .btn-minimal {
            padding: 11px 14px;
            font-size: 14px;
        }
    }
</style>

<div class="layout-wrapper" id="AppContainer" data-lang="PL">

    <div class="left-column">

        <div class="form-header">
            <h1 class="page-title">
                <span class="lang-pl">Demo eService GPAPI .NET SDK</span>
                <span class="lang-en">eService GPAPI .NET SDK Demo</span>
            </h1>

            <div class="lang-switcher">
                <button type="button"
                        class="lang-btn"
                        onclick="setLanguage('PL')">
                    PL
                </button>

                <button type="button"
                        class="lang-btn"
                        onclick="setLanguage('EN')">
                    EN
                </button>
            </div>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-box">
                <strong>
                    <span class="lang-pl">Błąd:</span>
                    <span class="lang-en">Error:</span>
                </strong>

                @ViewBag.Error
            </div>
        }

        <form asp-controller="Payment"
              asp-action="Index"
              method="post"
              class="checkout-form">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="validation-summary">
            </div>

            <input type="hidden"
                   asp-for="Language"
                   id="LanguageInput"
                   value="PL" />

            <input type="hidden"
                   asp-for="Amount"
                   value="@amount"
                   id="AmountInput" />

            <h2>
                <span class="lang-pl">1. Dane kontaktowe</span>
                <span class="lang-en">1. Contact Details</span>
            </h2>

            <div class="form-card">

                <div class="form-group">
                    <label asp-for="FirstName">
                        <span class="lang-pl">Imię</span>
                        <span class="lang-en">First Name</span>
                        <span class="required">*</span>
                    </label>

                    <input asp-for="FirstName" />

                    <span asp-validation-for="FirstName"
                          class="field-validation-error"></span>

                </div>

                <div class="form-group">
                    <label asp-for="LastName">
                        <span class="lang-pl">Nazwisko</span>
                        <span class="lang-en">Last Name</span>
                        <span class="required">*</span>
                    </label>

                    <input asp-for="LastName" />

                    <span asp-validation-for="LastName"
                          class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email">
                        <span class="lang-pl">Email</span>
                        <span class="lang-en">Email</span>
                        <span class="required">*</span>
                    </label>

                    <input asp-for="Email" type="email" />

                    <span asp-validation-for="Email"
                          class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Address">
                        <span class="lang-pl">Adres</span>
                        <span class="lang-en">Address</span>
                        <span class="required">*</span>
                    </label>

                    <input asp-for="Address" />

                    <span asp-validation-for="Address"
                          class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="City">
                        <span class="lang-pl">Miasto</span>
                        <span class="lang-en">City</span>
                        <span class="required">*</span>
                    </label>

                    <input asp-for="City" />

                    <span asp-validation-for="City"
                          class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PostalCode">
                        <span class="lang-pl">Kod pocztowy</span>
                        <span class="lang-en">Postal Code</span>
                        <span class="required">*</span>
                    </label>

                    <input asp-for="PostalCode" />

                    <span asp-validation-for="PostalCode"
                          class="field-validation-error"></span>
                </div>

            </div>

            <h2>
                <span class="lang-pl">2. Wybierz metodę płatności</span>
                <span class="lang-en">2. Select payment method</span>
            </h2>

            <div class="payment-box">

                <!-- KARTA / HPP -->

                <div class="payment-method">

                    <div class="payment-method-row">

                        <div class="payment-logo">
                            <img src="~/images/payments/cards.png"
                                 alt="Karta płatnicza" />
                        </div>

                        <button type="submit"
                                class="btn-minimal"
                                formaction="@Url.Action("Index", "Payment")">

                            <span class="lang-pl">
                                Karta na HPP
                            </span>

                            <span class="lang-en">
                                Pay by card via HPP
                            </span>

                        </button>

                    </div>

                    <div class="payment-note">

                        <span class="lang-pl">
                            Demonstracja Hosted Payment Page:
                        </span>

                        <span class="lang-en">
                            Hosted Payment Page demonstration:
                        </span>

                        <br />

                        <a href="https://developer.eservicegateway.com/docs/payments/online/hosted-payment-page-overview"
                           target="_blank"
                           rel="noopener noreferrer">

                            <span class="lang-pl">
                                Zobacz dokumentację eService &rarr;
                            </span>

                            <span class="lang-en">
                                View eService documentation &rarr;
                            </span>

                        </a>

                    </div>

                </div>

                <!-- BLIK -->

                <div class="payment-method">

                    <div class="payment-method-row">

                        <div class="payment-logo">
                            <img src="~/images/payments/blik.png"
                                 alt="BLIK" />
                        </div>

                        <button type="submit"
                                class="btn-minimal btn-blik"
                                formaction="@Url.Action("Blik", "Payment")">

                            <span class="lang-pl">
                                BLIK
                            </span>

                            <span class="lang-en">
                                Pay with BLIK
                            </span>

                        </button>

                    </div>

                    <div class="payment-note">

                        <span class="lang-pl">
                            Demonstracja APM BLIK:
                        </span>

                        <span class="lang-en">
                            APM BLIK demonstration:
                        </span>

                        <br />

                        <a href="https://developer.eservicegateway.com/docs/payments/payment-methods/blik-overview"
                           target="_blank"
                           rel="noopener noreferrer">

                            <span class="lang-pl">
                                Zobacz dokumentację eService &rarr;
                            </span>

                            <span class="lang-en">
                                View eService documentation &rarr;
                            </span>

                        </a>

                    </div>

                </div>

                <!-- BANK PAYMENT -->

                <div class="payment-method">

                    <div class="payment-method-row">

                        <div class="payment-logo">
                            <img src="~/images/payments/bank.png"
                                 alt="Bank Payment" />
                        </div>

                        <button type="submit"
                                class="btn-minimal btn-bank-payment"
                                formaction="@Url.Action("BankPayment", "Payment")">

                            <span class="lang-pl">
                                Szybki przelew bankowy
                            </span>

                            <span class="lang-en">
                                Pay with Bank Payment
                            </span>

                        </button>

                    </div>

                    <div class="payment-note">

                        <span class="lang-pl">
                            Demonstracja Bank Payment:
                        </span>

                        <span class="lang-en">
                            Bank Payment demonstration:
                        </span>

                        <br />

                        <a href="https://developer.eservicegateway.com/docs/payments/payment-methods/bank-payment-guide"
                           target="_blank"
                           rel="noopener noreferrer">

                            <span class="lang-pl">
                                Zobacz dokumentację eService &rarr;
                            </span>

                            <span class="lang-en">
                                View eService documentation &rarr;
                            </span>

                        </a>

                    </div>

                </div>

                <!-- eRATY -->

                <div class="payment-method">

                    <div class="payment-method-row">

                        <div class="payment-logo">
                            <img src="~/images/payments/eraty.svg"
                                 alt="eRaty" />
                        </div>

                        <button type="submit"
                                class="btn-minimal btn-eraty"
                                formaction="@Url.Action("ERaty", "Payment")">

                            <span class="lang-pl">
                                eRaty 10 rat 0%
                            </span>

                            <span class="lang-en">
                                Pay with eRaty 10 installments 0%
                            </span>

                        </button>

                    </div>

                    <div class="payment-note">

                        <span class="lang-pl">
                            Demonstracja APM eRaty:
                        </span>

                        <span class="lang-en">
                            APM eRaty demonstration:
                        </span>

                        <br />

                        <a href="https://developer.eservicegateway.com/docs/payments/payment-methods/eraty-overview"
                           target="_blank"
                           rel="noopener noreferrer">

                            <span class="lang-pl">
                                Zobacz dokumentację eService &rarr;
                            </span>

                            <span class="lang-en">
                                View eService documentation &rarr;
                            </span>

                        </a>

                    </div>

                </div>

            </div>

        </form>

    </div>

    <div class="right-column">

        <div class="product-summary">

            <h2 class="summary-title">

                <span class="lang-pl">
                    Podsumowanie zamówienia
                </span>

                <span class="lang-en">
                    Order Summary
                </span>

            </h2>

            <div class="product-image-placeholder">

                <img src="~/images/payments/terminal.jpg"
                     alt="Terminal płatniczy od eService" />

            </div>

            <div class="product-details">

                <div class="product-row">

                    <span>
                        <span class="lang-pl">
                            Niezawodny terminal
                        </span>

                        <span class="lang-en">
                            Reliable POS
                        </span>
                    </span>

                    <span>1 x</span>

                </div>

                <div class="product-description">

                    <span class="lang-pl">
                        od najlepszej firmy :)
                    </span>

                    <span class="lang-en">
                        from the best company :)
                    </span>

                </div>

            </div>

            <div class="product-total">

                <span>
                    <span class="lang-pl">
                        Do zapłaty:
                    </span>

                    <span class="lang-en">
                        Total:
                    </span>
                </span>

                <span>
                    @amount.ToString(
                        "0.00",
                        System.Globalization.CultureInfo.InvariantCulture
                    ) PLN
                </span>

            </div>

        </div>

    </div>

</div>

<script>
    function setLanguage(lang) {
        document.getElementById("LanguageInput").value = lang;

        document
            .getElementById("AppContainer")
            .setAttribute("data-lang", lang);
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}