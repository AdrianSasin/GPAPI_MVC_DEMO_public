@model GPAPI_MVC_DEMO.Models.PaymentRequestModel

@{
    decimal amount = 21.37m;
}

<style>
    :root {
        --surface: #f8fafc;
        --white: #fff;
        --border: #e5e7eb;
        --text: #1e293b;
        --muted: #6b7280;
        --radius: 8px;
    }

    * {
        box-sizing: border-box;
    }

    .layout-wrapper {
        display: flex;
        gap: 30px;
        max-width: 1000px;
        margin: 0 auto;
        color: #333;
    }

    .left-column {
        display: flex;
        flex: 1 1 50%;
        flex-direction: column;
        min-width: 300px;
    }

    .product-summary,
    .payment-box {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
    }

    .product-summary {
        position: sticky;
        top: 20px;
        flex: 0 1 350px;
        height: fit-content;
        padding: 30px;
        border-radius: 12px;
    }

    .checkout-form {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .form-header,
    .payment-method-row,
    .product-row,
    .product-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .form-header {
        align-items: flex-start;
        margin-bottom: 25px;
    }

    .page-title {
        margin: 0;
        font-size: 24px;
        font-weight: 600;
    }

    .lang-switcher {
        display: flex;
        gap: 5px;
    }

    .lang-btn,
    .btn-minimal {
        border: 0;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 500;
        transition: background-color .2s;
    }

    .lang-btn {
        padding: 5px 10px;
        border: 1px solid var(--border);
        background: #f3f4f6;
        color: #374151;
        font-weight: 700;
    }

        .lang-btn:hover {
            background: var(--border);
        }

    #AppContainer[data-lang="EN"] .lang-pl,
    #AppContainer[data-lang="PL"] .lang-en {
        display: none !important;
    }

    .error-box {
        margin-bottom: 25px;
        padding: 12px;
        border-left: 4px solid #ef4444;
        border-radius: 6px;
        background: #fef2f2;
        color: #991b1b;
        font-size: 14px;
    }

    h2 {
        font-size: 20px;
        font-weight: 600;
        margin: 0 0 20px;
        color: #1e293b;
    }


    .summary-title {
        font-size: 18px;
        font-weight: 600;
    }


    .form-card {
        margin-bottom: 20px;
        padding: 20px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--white);
        box-shadow: 2px 2px 4px rgb(0 0 0 / 10%), -2px -2px 4px var(--white);
    }

    .form-group {
        margin-bottom: 15px;
    }

        .form-group:last-child {
            margin-bottom: 0;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            color: #555;
            font-size: 14px;
            font-weight: 500;
        }

        .form-group input:not([type="hidden"]) {
            width: 100%;
            padding: 10px;
            border: 1px solid var(--border);
            border-radius: 6px;
            outline: 0;
            background: #fafafa;
            font-size: 14px;
            transition: border-color .2s, background-color .2s;
        }

        .form-group input:focus {
            border-color: #9ca3af;
            background: var(--white);
        }

    .payment-box {
        margin-top: 25px;
        padding: 24px;
        box-shadow: 4px 4px 8px rgb(0 0 0 / 8%), -4px -4px 8px var(--white);
    }

    .payment-method {
        margin-bottom: 25px;
    }

        .payment-method:last-child {
            margin-bottom: 0;
        }

    .payment-method-row {
        justify-content: flex-start;
        margin-bottom: 8px;
    }

    .payment-logo {
        flex: 0 0 70px;
        margin-right: 20px;
        text-align: center;
    }

        .payment-logo img {
            width: 100%;
            max-width: 50px;
            max-height: 70px;
            object-fit: contain;
            opacity: .9;
        }

    .btn-minimal {
        width: 100%;
        padding: 12px 24px;
        background: #475569;
        color: var(--white);
        font-size: 15px;
        text-align: center;
    }

        .btn-minimal:hover {
            background: #334155;
        }

    .btn-blik {
        background: #9f1239;
    }

        .btn-blik:hover {
            background: #881337;
        }

    .btn-bank-payment {
        background: #0369a1;
    }

        .btn-bank-payment:hover {
            background: #075985;
        }

    .btn-eraty {
        background: #7c3aed;
    }

        .btn-eraty:hover {
            background: #6d28d9;
        }

    .payment-note {
        margin-top: 5px;
        padding-left: 90px;
        min-height: 58px; /* wszystkie opisy mają taką samą wysokość */
        color: var(--muted);
        font-size: 13px;
        line-height: 1.4;
    }

        .payment-note a {
            color: #2563eb;
            text-decoration: none;
        }

            .payment-note a:hover {
                text-decoration: underline;
            }

    .product-image-placeholder {
        height: 200px;
        margin-bottom: 20px;
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--white);
    }

        .product-image-placeholder img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .product-details {
        margin-bottom: 15px;
        padding: 15px 0;
        border-block: 1px solid var(--border);
    }

    .product-row {
        margin-bottom: 8px;
    }

    .product-description {
        color: var(--muted);
        font-size: 13px;
    }

    .product-total {
        font-size: 18px;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .layout-wrapper {
            flex-direction: column-reverse;
            gap: 20px;
        }

        .product-summary {
            position: static;
            flex: 1 1 auto;
            max-width: 100%;
        }
    }
</style>

<div class="layout-wrapper" id="AppContainer" data-lang="PL">

    <div class="left-column">

        <div class="form-header">
            <h1 class="page-title">
                <span class="lang-pl">Demo eService GPAPI .NET SDK</span>
                <span class="lang-en">eService GPAPI .NET SDK Demo</span>
            </h1>

            <div class="lang-switcher">
                <button type="button"
                        class="lang-btn"
                        onclick="setLanguage('PL')">
                    PL
                </button>

                <button type="button"
                        class="lang-btn"
                        onclick="setLanguage('EN')">
                    EN
                </button>
            </div>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-box">

                <strong>
                    <span class="lang-pl">Błąd:</span>
                    <span class="lang-en">Error:</span>
                </strong>

                @ViewBag.Error
            </div>
        }

        <form asp-controller="Payment"
              asp-action="Index"
              method="post"
              class="checkout-form">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   asp-for="Language"
                   id="LanguageInput"
                   value="PL" />

            <input type="hidden"
                   asp-for="Amount"
                   value="@amount"
                   id="AmountInput" />

            <h2>
                <span class="lang-pl">1. Dane kontaktowe</span>
                <span class="lang-en">1. Contact Details</span>
            </h2>

            <div class="form-card">

                <div class="form-group">
                    <label asp-for="FirstName">
                        <span class="lang-pl">Imię</span>
                        <span class="lang-en">First Name</span>
                    </label>

                    <input asp-for="FirstName" />
                </div>

                <div class="form-group">
                    <label asp-for="LastName">
                        <span class="lang-pl">Nazwisko</span>
                        <span class="lang-en">Last Name</span>
                    </label>

                    <input asp-for="LastName" />
                </div>

                <div class="form-group">
                    <label asp-for="Email">
                        <span class="lang-pl">Email</span>
                        <span class="lang-en">Email</span>
                    </label>

                    <input asp-for="Email" type="email" />
                </div>

                <div class="form-group">
                    <label asp-for="Address">
                        <span class="lang-pl">Adres</span>
                        <span class="lang-en">Address</span>
                    </label>

                    <input asp-for="Address" />
                </div>

                <div class="form-group">
                    <label asp-for="City">
                        <span class="lang-pl">Miasto</span>
                        <span class="lang-en">City</span>
                    </label>

                    <input asp-for="City" />
                </div>

                <div class="form-group">
                    <label asp-for="PostalCode">
                        <span class="lang-pl">Kod pocztowy</span>
                        <span class="lang-en">Postal Code</span>
                    </label>

                    <input asp-for="PostalCode" />
                </div>

            </div>

            <h2>
                <span class="lang-pl">2. Wybierz metodę płatności</span>
                <span class="lang-en">2. Select payment method</span>
            </h2>

            <div class="payment-box">

                <!-- KARTA / HPP -->

                <div class="payment-method">

                    <div class="payment-method-row">

                        <div class="payment-logo">
                            <img src="~/images/payments/cards.png"
                                 alt="Karta płatnicza" />
                        </div>

                        <button type="submit"
                                class="btn-minimal"
                                formaction="@Url.Action("Index", "Payment")">

                            <span class="lang-pl">
                                Karta na HPP
                            </span>

                            <span class="lang-en">
                                Pay by card via HPP
                            </span>

                        </button>

                    </div>

                    <div class="payment-note">

                        <span class="lang-pl">
                            Demonstracja Hosted Payment Page:
                        </span>

                        <span class="lang-en">
                            Hosted Payment Page demonstration:
                        </span>

                        <br />

                        <a href="https://developer.eservicegateway.com/docs/payments/online/hosted-payment-page-overview"
                           target="_blank"
                           rel="noopener noreferrer">

                            <span class="lang-pl">
                                Zobacz dokumentację eService &rarr;
                            </span>

                            <span class="lang-en">
                                View eService documentation &rarr;
                            </span>

                        </a>

                    </div>

                </div>

                <!-- BLIK -->

                <div class="payment-method">

                    <div class="payment-method-row">

                        <div class="payment-logo">
                            <img src="~/images/payments/blik.png"
                                 alt="BLIK" />
                        </div>

                        <button type="submit"
                                class="btn-minimal btn-blik"
                                formaction="@Url.Action("Blik", "Payment")">

                            <span class="lang-pl">
                                BLIK
                            </span>

                            <span class="lang-en">
                                Pay with BLIK
                            </span>

                        </button>

                    </div>

                    <div class="payment-note">

                        <span class="lang-pl">
                            Demonstracja APM BLIK:
                        </span>

                        <span class="lang-en">
                            APM BLIK demonstration:
                        </span>

                        <br />

                        <a href="https://developer.eservicegateway.com/docs/payments/payment-methods/blik-overview"
                           target="_blank"
                           rel="noopener noreferrer">

                            <span class="lang-pl">
                                Zobacz dokumentację eService &rarr;
                            </span>

                            <span class="lang-en">
                                View eService documentation &rarr;
                            </span>

                        </a>

                    </div>

                </div>

                <!-- BANK PAYMENT -->

                <div class="payment-method">

                    <div class="payment-method-row">

                        <div class="payment-logo">
                            <img src="~/images/payments/bank.png"
                                 alt="Bank Payment" />
                        </div>

                        <button type="submit"
                                class="btn-minimal btn-bank-payment"
                                formaction="@Url.Action("BankPayment", "Payment")">

                            <span class="lang-pl">
                                Szybki przelew bankowy
                            </span>

                            <span class="lang-en">
                                Pay with Bank Payment
                            </span>

                        </button>

                    </div>

                    <div class="payment-note">

                        <span class="lang-pl">
                            Demonstracja Bank Payment:
                        </span>

                        <span class="lang-en">
                            Bank Payment demonstration:
                        </span>

                        <br />

                        <a href="https://developer.eservicegateway.com/docs/payments/payment-methods/bank-payment-guide"
                           target="_blank"
                           rel="noopener noreferrer">

                            <span class="lang-pl">
                                Zobacz dokumentację eService &rarr;
                            </span>

                            <span class="lang-en">
                                View eService documentation &rarr;
                            </span>

                        </a>

                    </div>

                </div>

                <!-- eRATY -->

                <div class="payment-method">

                    <div class="payment-method-row">

                        <div class="payment-logo">
                            <img src="~/images/payments/eraty.svg"
                                 alt="eRaty" />
                        </div>

                        <button type="submit"
                                class="btn-minimal btn-eraty"
                                formaction="@Url.Action("ERaty", "Payment")">

                            <span class="lang-pl">
                                eRaty 10 rat 0%
                            </span>

                            <span class="lang-en">
                                Pay with eRaty 10 installments 0%
                            </span>

                        </button>

                    </div>

                    <div class="payment-note">

                        <span class="lang-pl">
                            Demonstracja APM eRaty:
                        </span>

                        <span class="lang-en">
                            APM eRaty demonstration:
                        </span>

                        <br />

                        <a href="https://developer.eservicegateway.com/docs/payments/payment-methods/eraty-overview"
                           target="_blank"
                           rel="noopener noreferrer">

                            <span class="lang-pl">
                                Zobacz dokumentację eService &rarr;
                            </span>

                            <span class="lang-en">
                                View eService documentation &rarr;
                            </span>

                        </a>

                    </div>

                </div>

            </div>

        </form>

    </div>

    <div class="product-summary">

        <h2 class="summary-title">

            <span class="lang-pl">
                Podsumowanie zamówienia
            </span>

            <span class="lang-en">
                Order Summary
            </span>

        </h2>

        <div class="product-image-placeholder">

            <img src="~/images/payments/terminal.jpg"
                 alt="Terminal płatniczy od eService" />

        </div>

        <div class="product-details">

            <div class="product-row">

                <span>
                    <span class="lang-pl">
                        Niezawodny terminal
                    </span>

                    <span class="lang-en">
                        Reliable POS
                    </span>
                </span>

                <span>1 x</span>

            </div>

            <div class="product-description">

                <span class="lang-pl">
                    od najlepszej firmy :)
                </span>

                <span class="lang-en">
                    from the best company :)
                </span>

            </div>

        </div>

        <div class="product-total">

            <span>
                <span class="lang-pl">
                    Do zapłaty:
                </span>

                <span class="lang-en">
                    Total:
                </span>
            </span>

            <span>
                @amount.ToString(
                "0.00",
                                System.Globalization.CultureInfo.InvariantCulture
                                ) PLN
            </span>

        </div>

    </div>

</div>

<script>
    function setLanguage(lang) {
        document.getElementById("LanguageInput").value = lang;

        document
            .getElementById("AppContainer")
            .setAttribute("data-lang", lang);
    }
</script>