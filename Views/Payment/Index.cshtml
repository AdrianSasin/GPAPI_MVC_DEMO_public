@model GPAPI_MVC_DEMO.Models.PaymentRequestModel

<style>
    .minimal-container {
        background-color: #ffffff;
        padding: 30px;
        border: 1px solid #eaeaea;
        max-width: 600px;
        color: #333;
        font-family: inherit;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-group label {
        display: block;
        margin-bottom: 5px;
        font-weight: 500;
        color: #555;
        font-size: 14px;
    }

    .form-group input {
        width: 100%;
        padding: 10px;
        border: 1px solid #d1d5db;
        font-size: 14px;
        box-sizing: border-box;
        outline: none;
        transition: border-color 0.2s;
        background-color: #fafafa;
    }

    .form-group input:focus {
        border-color: #9ca3af;
        background-color: #ffffff;
    }

    .btn-minimal {
        background-color: #475569;
        color: #ffffff;
        border: none;
        padding: 12px 24px;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        transition: background-color 0.2s ease-in-out;
        min-width: 240px;
        text-align: center;
    }

    .btn-minimal:hover {
        background-color: #334155;
    }

    .btn-blik {
        background-color: #9f1239;
    }

    .btn-blik:hover {
        background-color: #881337;
    }

    .payment-box {
        border: 1px solid #f3f4f6;
        padding: 24px;
        margin-top: 25px;
        background-color: #f8fafc;
    }

    .payment-note {
        padding-left: 80px; 
        font-size: 13px; 
        color: #6b7280; 
        line-height: 1.4;
    }

    .payment-note a {
        color: #2563eb;
        text-decoration: none;
    }

    .payment-note a:hover {
        text-decoration: underline;
    }
</style>

<div class="minimal-container">
    <h1 style="font-size: 24px; font-weight: 600; margin-bottom: 25px;">Demo eService GPAPI .NET SDK</h1>

    @if (ViewBag.Error != null)
    {
        <div style="background-color: #fef2f2; border-left: 4px solid #ef4444; color: #991b1b; padding: 12px; margin-bottom: 25px; font-size: 14px;">
            <strong>Błąd:</strong> @ViewBag.Error
        </div>
    }

    <form asp-action="Index" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Imię</label>
            <input asp-for="FirstName" />
        </div>

        <div class="form-group">
            <label>Nazwisko</label>
            <input asp-for="LastName" />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input asp-for="Email" />
        </div>

        <div class="form-group">
            <label>Adres</label>
            <input asp-for="Address" />
        </div>

        <div class="form-group">
            <label>Miasto</label>
            <input asp-for="City" />
        </div>

        <div class="form-group">
            <label>Kod pocztowy</label>
            <input asp-for="PostalCode" />
        </div>

        <div class="form-group">
            <label>Kwota</label>
            <input asp-for="Amount" />
        </div>

        <div class="form-group">
            <label>Język</label>
            <input asp-for="Language" />
        </div>

        <div class="payment-box">
            <p style="font-weight: 600; font-size: 16px; margin-top: 0; margin-bottom: 20px; color: #1e293b;">
                Wybierz metodę płatności:
            </p>
            
            <div style="margin-bottom: 25px;">
                <div style="display: flex; align-items: center; margin-bottom: 8px;">
                    <div style="width: 60px; text-align: center; margin-right: 20px;">
                        <img src="~/images/payments/cards.png" alt="Karta płatnicza" style="width: 100%; max-width: 50px; opacity: 0.9;" />
                    </div>
                    <button type="submit" class="btn-minimal" formaction="/Payment/Index">
                        Zapłać kartą przez HPP
                    </button>
                </div>
                <div class="payment-note">
                    Demonstracja Hosted Payment Page: <br />
                    <a href="https://developer.eservicegateway.com/docs/payments/online/hosted-payment-page-overview" target="_blank">Zobacz dokumentację eService &rarr;</a>
                </div>
            </div>

            <div>
                <div style="display: flex; align-items: center; margin-bottom: 8px;">
                    <div style="width: 60px; text-align: center; margin-right: 20px;">
                        <img src="~/images/payments/blik.png" alt="BLIK" style="width: 100%; max-width: 50px; opacity: 0.9;" />
                    </div>
                    <button type="submit" class="btn-minimal btn-blik" formaction="/Payment/Blik">
                        Zapłać BLIK
                    </button>
                </div>
                <div class="payment-note">
                    Demonstracja APM BLIK: <br />
                    <a href="https://developer.eservicegateway.com/docs/payments/payment-methods/blik-overview" target="_blank">Zobacz dokumentację eService &rarr;</a>
                </div>
            </div>
        </div>
    </form>
</div>